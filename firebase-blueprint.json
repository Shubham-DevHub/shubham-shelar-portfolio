{
  "entities": {
    "contact": {
      "title": "Contact",
      "description": "A contact form message submission",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The full name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message body sent by the sender."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp indicating when the message was submitted."
        }
      },
      "required": [
        "fullName",
        "email",
        "message",
        "createdAt"
      ]
    },
    "project_entity": {
      "title": "Project",
      "description": "An interactive portfolio showcase project",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the project."
        },
        "title": {
          "type": "string",
          "description": "Title of the project."
        },
        "description": {
          "type": "string",
          "description": "Description of the project."
        },
        "image": {
          "type": "string",
          "description": "Image URL for the project thumbnail."
        },
        "githubUrl": {
          "type": "string",
          "description": "Optional GitHub URL."
        },
        "demoUrl": {
          "type": "string",
          "description": "Optional Live Demo URL."
        },
        "tags": {
          "type": "array",
          "description": "Tags of technologies used in the project."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this project was last updated."
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "image",
        "tags"
      ]
    },
    "resume_entity": {
      "title": "Resume Data",
      "description": "Dynamic resume texts and fields",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "skillsLine": {
          "type": "string",
          "description": "Comma-separated list of languages & core skills."
        },
        "frameworksLine": {
          "type": "string",
          "description": "Comma-separated list of frameworks."
        },
        "cloudLine": {
          "type": "string",
          "description": "Comma-separated list of cloud technologies."
        },
        "dbLine": {
          "type": "string",
          "description": "Comma-separated database technologies."
        },
        "aiLine": {
          "type": "string",
          "description": "Comma-separated AI/LLM integrations used."
        },
        "toolsLine": {
          "type": "string",
          "description": "Comma-separated tools."
        },
        "featuredWorkText": {
          "type": "string",
          "description": "Customizable featured work experience markdown text or copy."
        },
        "educationText": {
          "type": "string",
          "description": "Customizable education experience markdown text or copy."
        },
        "certificationsList": {
          "type": "array",
          "description": "List of dynamic certifications."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "fullName",
        "tagline",
        "email",
        "phone",
        "location",
        "summary",
        "updatedAt"
      ]
    }
  },
  "firestore": {
    "/contact_messages/{messageId}": {
      "schema": "contact",
      "description": "Collection of contact form messages."
    },
    "/projects/{projectId}": {
      "schema": "project_entity",
      "description": "Dynamic collection of showcase projects."
    },
    "/resume_config/{configId}": {
      "schema": "resume_entity",
      "description": "Singleton configuration config documents for resume information."
    }
  }
}
